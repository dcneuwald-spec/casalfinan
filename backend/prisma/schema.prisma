generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Use DATABASE_URL env var
  // For local dev: "file:./dev.db" (SQLite)
  // For production: postgresql://... (Neon, Supabase, etc.)
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  coupleId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  couple       Couple?       @relation("CoupleMembers", fields: [coupleId], references: [id])
  coupleOwned  Couple?       @relation("CoupleOwner")
  transactions Transaction[]
  creditCards  CreditCard[]
  budgets      Budget[]
  bills        Bill[]

  @@map("users")
}

model Couple {
  id          String   @id @default(uuid())
  name        String
  inviteCode  String   @unique
  ownerId     String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User        @relation("CoupleOwner", fields: [ownerId], references: [id])
  members    User[]      @relation("CoupleMembers")
  categories Category[]

  @@map("couples")
}

model Category {
  id       String  @id @default(uuid())
  name     String
  icon     String
  color    String
  type     String  // 'income' | 'expense' | 'both'
  coupleId String

  couple       Couple        @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

model Transaction {
  id           String   @id @default(uuid())
  description  String
  amount       Float
  type         String   // 'income' | 'expense'
  date         DateTime
  notes        String?
  isPaid       Boolean  @default(true)
  isShared     Boolean  @default(false)
  recurrence   String?  // 'none' | 'daily' | 'weekly' | 'monthly' | 'yearly'
  userId       String
  categoryId   String
  creditCardId String?
  billId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category    @relation(fields: [categoryId], references: [id])
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id])
  bill       Bill?       @relation(fields: [billId], references: [id])

  @@map("transactions")
}

model CreditCard {
  id           String  @id @default(uuid())
  name         String
  bank         String
  limit        Float
  closingDay   Int
  dueDay       Int
  color        String
  userId       String
  coupleShared Boolean @default(false)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("credit_cards")
}

model Bill {
  id          String   @id @default(uuid())
  description String
  amount      Float
  dueDay      Int
  categoryId  String?
  userId      String
  isActive    Boolean  @default(true)
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("bills")
}

model Budget {
  id         String @id @default(uuid())
  amount     Float
  month      Int
  year       Int
  categoryId String
  userId     String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, userId, month, year])
  @@map("budgets")
}
